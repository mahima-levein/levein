---
import Header from "@components/Header.astro"
import Footer from "@components/Footer.astro"
import "@styles/global.css";

interface Props {
  title?: string;
  description?: string;
}
const { title = "Levein Group", description = "Levein Group is a UK-based company with a Global Capacity Center in Colombo, Sri Lanka, specializing in supporting startups and hypergrowth firms, particularly in the tech and healthcare industries." } : Props = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Averia+Serif+Libre:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body>
		<Header />
		<slot />
		<Footer />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		scroll-behavior: smooth;
	}
</style>
  <script>
    import { initDmReveal, initTextReveal } from "../scripts/text-reveal";
    import { initTechStackDepth } from "../scripts/tech-stack-depth";

    const boot = () => {
      initTextReveal(document);
      initDmReveal(document);
      initTechStackDepth(document);
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", boot, { once: true });
    } else {
      boot();
    }

    document.addEventListener("astro:page-load", boot);
  </script>
