---
import Layout from "../layouts/Layout.astro";
import Hero from "@components/HeroSection.astro";
const org = {
  name: "Levein Technologies Ltd",
  url: "www.leveingroup.com",
  email: "info@leveingroup.com",
  address:
    " Design Boo Private Limited, 1st Floor, No 40, Poorwarama Road, Nugegoda, Sri Lanka",
  lastUpdated: "2026-05-14",
};
---

<Layout
  title="Privacy Policy"
  description="Read our privacy policy to understand how we collect, use, and protect your information across our website, job platform, and services."
>
  <Hero
    title="Privacy Policy"
    description="Read our privacy policy to understand how we collect, use, and protect your information across our website, job platform, and services."
  />
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="mb-4 flex flex-col justify-center items-center gap-2">
      <p class="flex items-center gap-2 text-[16px] text-gray-500">
        Last updated: <time datetime={org.lastUpdated}>{org.lastUpdated}</time>
      </p>
    </div>
    <!-- Body -->
    <article class="lg:col-span-9 pp-article space-y-10">
      <section id="who-we-are" class="pp-card">
        <h2>1. Who we are</h2>
        <br />
        <p>
          {org.name} provides offshore hiring, workforce solutions, and a job platform
          for candidates and employers. Our website is
          {org.url}.
        </p>This Privacy Policy explains how <span class="font-bold"
          >Levein Technologies Ltd
        </span> collects, uses, and protects your personal information when you visit
        our Website, use our job platform, submit an application, or contact us. We
        comply with the<span class="font-bold">
          Sri Lanka Personal Data Protection Act (PDPA) 2022</span
        > and are committed to safeguarding your privacy. If you have any questions
        about this policy, please contact us at <a href={`mailto:${org.email}`}
          >{org.email}</a
        >.
      </section>
    </article>

    <section id="data-we-collect" class="pp-card">
      <h2>2. Data Controller</h2>
      <ul class="pp-list">
        <li>Name, email address, phone number, company name, and job title.</li>
        <li>Company information (name, address, registration details)</li>
        <li>Business requirements (workforce needs, team structure)</li>
        <li>
          Candidate details, CVs, application history, and employment
          preferences.
        </li>
        <li>Communication records (emails, calls, meetings)</li>
        <li>Technical data (IP address, browser type, device information)</li>
        <li>Usage data (how you use our website and services)</li>
      </ul>
    </section>

    <section id="how-we-use" class="pp-card">
      <h2>3. Personal Data We Process</h2>
      <p class="pp-description">
        We process the following categories of personal data:
      </p>
      <ul class="pp-list">
        <li>
          Provide and improve our services, website, and customer support.
        </li>
        <li>
          Respond to enquiries, process applications, and schedule
          consultations.
        </li>
        <li>
          Support recruitment, candidate matching, and job platform features.
        </li>
        <li>
          Security, fraud prevention, and to comply with legal obligations.
        </li>
        <li>Send relevant updates or marketing (you can opt out anytime).</li>
        <li>
          Analytics to understand performance and improve user experience.
        </li>
      </ul>
    </section>

    <section id="lawful-basis" class="pp-card">
      <h2>4. Legal Basis for Processing:</h2>
      <p class="pp-description">
        We rely on one or more of the following lawful bases to process your
        personal data:
      </p>
      <ul class="pp-list">
        <li>
          Contract performance: Processing necessary for contracts we enter into
          with you
        </li>
        <li>Legitimate interests: To provide and improve our services</li>
        <li>Legal obligation: To comply with legal requirements</li>
        <li>Consent: Where specifically requested and provided by you</li>
      </ul>
    </section>

    <section id="sharing" class="pp-card">
      <h2>5. Purposes of Processing</h2>
      <p class="pp-description">
        We process your data for the following purposes:
      </p>
      <ul class="pp-list">
        <li>Understand your offshore workforce needs</li>
        <li>Build and manage your offshore team</li>
        <li>Handle recruitment and HR operations</li>
        <li>Manage job listings, applications, and candidate communications</li>
        <li>Process payroll and administrative tasks</li>
        <li>Improve our services and develop new features</li>
        <li>Comply with legal and regulatory obligations</li>
        <li>Prevent fraud and ensure security</li>
        <li>Communicate with you about our services</li>
      </ul>
    </section>

    <section id="retention" class="pp-card">
      <h2>6. Data retention</h2>
      <p class="pp-description">
        We retain your personal data for as long as necessary to:
      </p>
      <ul class="pp-list">
        <li>Provide our services to you</li>
        <li>Comply with legal obligations</li>
        <li>Resolve disputes</li>
        <li>Enforce our agreements</li>
        <li>Review and manage job applications and recruitment records</li>
      </ul>
      <p class="mt-2">
        When data is no longer needed, it will be securely deleted or
        anonymized.
      </p>
    </section>

    <section id="security" class="pp-card">
      <h2>7. International Transfers:</h2>
      <p class="pp-description">
        When we transfer data outside of Sri Lanka, we ensure appropriate safeguards are in place, such as:
      </p>
      <ul class="pp-list">
        <li>Standard Contractual Clauses</li>
        <li>Adequacy decisions</li>
        <li>Other legal transfer mechanisms</li>
      </ul>
    </section>

    <section id="your-rights" class="pp-card">
      <h2>8. Your rights</h2>
      <p class="pp-description">
        Under GDPR, you have the following rights: To exercise these rights,
        contact us at <a href={`mailto:${org.email}`}>{org.email}</a>.
      </p>
      <ul class="pp-list">
        <li>Right to access your personal data</li>
        <li>Right to rectification of inaccurate data</li>
        <li>Right to erasure ('right to be forgotten')</li>
        <li>Right to restrict processing</li>
        <li>Right to data portability</li>
        <li>Right to object to processing</li>
        <li>Rights related to automated decision making</li>
        <li>Right to withdraw consent</li>
      </ul>
      <p class="mt-2">
        To exercise your rights, contact our Data Protection Officer. We will
        respond within one month.
      </p>
      <p>
        You have the right to lodge a complaint with a supervisory authority.
      </p>
      <!-- <details class="pp-details">
                <summary>California (CCPA/CPRA) notice</summary>
                <p>
                  California residents may request details about categories of personal info we
                  collect, use, disclose, and sell/share (we do not sell personal info). You may
                  exercise rights to know, delete, correct, and limit use of sensitive information.
                </p>
              </details> -->
    </section>

    <section id="cookies" class="pp-card">
      <h2>9. Cookies</h2>
      <p>We use cookies and similar technologies to:</p>
      <table class="pp-table">
        <thead><tr><th>Type</th><th>Purpose</th><th>Examples</th></tr></thead>
        <tbody>
          <tr
            ><td>Essential</td><td>Core site functionality, security</td><td
              >Session ID</td
            ></tr
          >
          <tr
            ><td>Analytics</td><td>Usage measurement, performance</td><td
              >Page views, events</td
            ></tr
          >
          <tr
            ><td>Marketing</td><td>Measure campaigns, retargeting</td><td
              >Ad platform pixels</td
            ></tr
          >
        </tbody>
      </table>
    </section>

    <section id="changes" class="pp-card">
      <h2>10. Updates to This Policy</h2>
      <p>
        We may update this Privacy Policy from time to time to reflect changes
        in our practices or legal requirements. Any updates will be posted on
        this page with a revised "Effective Date." Continued use of the Website
        after updates means you accept the revised policy.
      </p>
    </section>

    <section id="contact" class="pp-card">
      <h2>11. Contact us</h2>
      <address class="not-italic">
        <strong>{org.name}</strong><br />
        {org.address}<br />
        <a href={`mailto:${org.email}`}>{org.email}</a>
      </address>
    </section>

    <div class="text-center">
      <a href="#top" class="pp-backtop">Back to top ↑</a>
    </div>
  </section>
</Layout>
<style is:global>
  .pp-card {
    display: block;
    margin-bottom: 1.5rem;
    background: #e3f0e02f;
    border: 1px solid #cccccc4b;
    border-radius: 24px;
    padding: 1.25rem 1.25rem;
  }
  .pp-card h2 {
    font-weight: 600;
    font-size: 18px;
    margin-bottom: 0.5rem;
  }
  .pp-card p {
    color: rgba(#111827, 0.9);
  }
  .pp-list {
    margin: 0.5rem 0 0 0;
    display: grid;
    gap: 0.35rem;
    color: rgba(17, 24, 39, 0.75);
    padding-left: 1.2rem;
    li {
      list-style: inside disc;
    }
  }
  .pp-list-terms {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 0.5rem 0 0 0;
    padding-left: 1.2rem;
    color: rgba(17, 24, 39, 0.75);
    list-style: none;
  }

  /* Table */
  .pp-table {
    width: 100%;
    margin-top: 0.75rem;
    border-collapse: collapse;
    font-size: 0.95rem;
    th,
    td {
      border: 1px solid rgba(17, 24, 39, 0.14);
      padding: 0.6rem 0.7rem;
    }
    thead th {
      background: rgba(326262, 0.08);
      color: #111827;
      text-align: left;
    }
  }

  /* Details */
  .pp-details {
    margin-top: 0.6rem;
    border: 1px dashed rgba(17, 24, 39, 0.14);
    border-radius: 10px;
    padding: 0.6rem 0.8rem;
    summary {
      cursor: pointer;
      font-weight: 600;
      color: 326262;
    }
  }

  /* Back to top */
  .pp-backtop {
    display: inline-block;
    margin-top: 0.25rem;
    padding: 0.6rem 1rem;
    border-radius: 0.6rem;
    background: 326262;
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    box-shadow: inset 0 -2px 0 rgba(255, 255, 255, 0.12);
    transition: opacity 0.2s ease;
    &:hover {
      opacity: 0.95;
    }
    color: #fff !important;
  }
  /* Links */
  .pp-root a {
    color: 326262;
  }

  /* Small screens */
  @media (max-width: 1024px) {
    .pp-toc {
      position: static;
    }
  }
  .pp-description {
    color: #0f204b;
    font-size: 16px;
    font-style: normal;
    font-weight: 600;
    line-height: 21px; /* 131.25% */
  }
</style>
