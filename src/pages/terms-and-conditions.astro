---
import Layout from "../layouts/Layout.astro";
import Hero from "@components/HeroSection.astro";
const org = {
  name: "Levein Technologies Ltd",
  url: "www.leveingroup.com",
  email: "info@leveingroup.com",
  address: " Design Boo Private Limited, 1st Floor, No 40, Poorwarama Road, Nugegoda, Sri Lanka",
  lastUpdated: "2026-05-14",
};
---
<Layout title="Terms and Conditions" description="Read our terms and conditions to understand the rules and guidelines for using our website and services.">
  <Hero title="Terms and Conditions" description="Read our terms and conditions to understand the rules and guidelines for using our website and services." />
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="mb-4 flex flex-col justify-center items-center gap-2">
            <p class="flex items-center gap-2 text-[16px] text-gray-500">
            Last updated: <time datetime={org.lastUpdated}>{org.lastUpdated}</time>
          </p>
        </div>
        <article class="lg:col-span-9 pp-article space-y-10">
            <section id="who-we-are" class="pp-card">
              <h2>1. Who we are</h2>
                <p>This website (www.leveingroup.com) is owned and operated by <span class="font-bold">Levein Technologies Ltd</span>, a company registered office at <span class="font-bold">{org.address}</span>
              </p>
              <p class="mt-2">By accessing and using this Website, you agree to comply with and be bound by these Terms and Conditions (“Terms”). If you do not agree, please do not use this Website.</p>
            </section>

            <section id="data-we-collect" class="pp-card">
              <h2>2. Use of This Website</h2>
              <ul class="pp-list-terms">
                <li>2.1 You agree to use this Website only for lawful purposes and in a manner that does not infringe the rights of, restrict, or inhibit anyone else's use and enjoyment of the Website</li>
                <li>2.2 You must not misuse this Website by knowingly introducing viruses, trojans, worms, logic bombs, or other malicious or harmful material.</li>
                <li>2.3 You must not attempt to gain unauthorised access to the Website, its servers, or any connected databases.</li>
                <li>2.4 We reserve the right to suspend or restrict access to any part of the Website at our discretion.</li>
              </ul>
            </section>

            <section id="how-we-use" class="pp-card">
              <h2>3. Information on This Website</h2>
              <ul class="pp-list-terms">
                <li>3.1 The information provided on this Website is for general informational and marketing purposes only. It does not constitute professional advice or a binding offer</li>
                <li>3.2 We make reasonable efforts to ensure that the information provided is accurate and up to date, but we make no representations or warranties of any kind, express or implied, about the completeness, accuracy, reliability, or suitability of the information.</li>
                <li>3.3 Any reliance you place on such information is strictly at your own risk.</li>
              </ul>
            </section>

            <section id="lawful-basis" class="pp-card">
              <h2>4. Enquiries and Services</h2>
              <ul class="pp-list-terms">
                <li>4.1 You may contact us through the Website to enquire about our outsourcing and staffing services.</li>
                <li>4.2 Submitting an enquiry does not create a contractual relationship. Any formal engagement for services will be subject to a separate written Service Agreement between you and Levein Technologies Ltd (trading as Your Team in Asia).</li>
                <li>4.3 We reserve the right to accept or decline enquiries at our discretion.</li>
              </ul>
            </section>

            <section id="sharing" class="pp-card">
              <h2>5. Intellectual Property Rights</h2>
              <ul class="pp-list-terms">
                <li>5.1 All content on this Website, including text, graphics, logos, designs, images, and software, is owned or licensed by Levein Technologies Ltd and is protected by copyright, trademark, and other intellectual property laws</li>
                <li>5.2 You may download or print materials for your personal, non-commercial use only.</li>
                <li>5.3 You must not modify, copy, distribute, or reproduce any materials without our prior written permission.</li>
            </ul>
            </section>

            <section id="retention" class="pp-card">
              <h2>6. Third-Party Links</h2>
              <ul class="pp-list-terms">
                <li>6.1 The Website may contain links to third-party websites or services for your convenience.</li>
                <li>6.2 We have no control over and accept no responsibility for the content, privacy policies, or practices of third-party websites.</li>
                <li>6.3 You access such third-party websites entirely at your own risk.</li>
            </ul>
            </section>

            <section id="security" class="pp-card">
              <h2>7. Data Protection and Privacy</h2>
              <ul class="pp-list-terms">
                <li>7.1 We are committed to protecting your privacy and complying with the laws of Sri Lanka regarding data protection and privacy.</li>
                <li>7.2 Personal information collected through this Website (e.g. via forms or cookies) is processed in accordance with our Privacy Policy, which can be found <a href="/privacy-policy">here</a>.</li>
                <li>7.3 By using this Website, you consent to such processing and warrant that all data provided by you is accurate.</li>
            </ul>
            </section>

            <section id="your-rights" class="pp-card">
              <h2>8. Cookies</h2>
              <ul class="pp-list-terms">
                <li>8.1 Our Website may use cookies to improve user experience, website functionality, and analytics.</li>
                <li>8.2 You can manage or disable cookies in your browser settings. For further details, please refer to our Cookie Policy.</li>
            </ul>
            </section>

            <section id="cookies" class="pp-card">
              <h2>9. Limitation of Liability</h2>
              <ul class="pp-list-terms">
                <li>9.1 To the fullest extent permitted by law, Levein Technologies Ltd (trading as Your Team in Asia) shall not be liable for any direct, indirect, incidental, or consequential damages arising from or related to your use of this Website.</li>
                <li>9.2 We do not guarantee that the Website will be free from errors, interruptions, or viruses.</li>
                <li>9.3 Nothing in these Terms shall limit or exclude liability for death or personal injury caused by negligence or any liability that cannot be excluded under the laws of Sri Lanka.</li>
            </ul>
            </section>

            <section id="changes" class="pp-card">
              <h2>10. Indemnity</h2>
              <p>
                You agree to indemnify and hold harmless Levein Technologies Ltd, Designboo (Pvt) Ltd, and their directors, employees, and affiliates from any claims, damages, or expenses arising from your use of the Website or your breach of these Terms.
              </p>
            </section>
            <section id="other-changes" class="pp-card">
              <h2>11. Changes to These Terms</h2>
              <p>
                We may update these Terms periodically. Any changes will be posted on this page with a revised “Effective Date.” Continued use of the Website after changes are made constitutes your acceptance of the updated Terms.
              </p>
            </section>
            <section id="law" class="pp-card">
              <h2>12. Governing Law</h2>
              <p>
                These Terms are governed by and construed in accordance with the laws of Sri Lanka. Any disputes arising under or in connection with these Terms shall be subject to the exclusive jurisdiction of the courts of Sri Lanka.
              </p>
            </section>

            <section id="contact" class="pp-card">
              <h2>13. Contact us</h2>
              <address class="not-italic">
                <strong>{org.name}</strong><br />
                {org.address}<br />
                <a href={`mailto:${org.email}`}>{org.email}</a>
              </address>
            </section>

            <div class="text-center">
              <a href="#top" class="pp-backtop">Back to top ↑</a>
            </div>
          </article>
    </section>
    <style is:global>
        .pp-card {
            display: block; 
            margin-bottom: 1.5rem;
            background: #e3f0e02f;
            border: 1px solid #cccccc4b;
            border-radius: 24px;
            padding: 1.25rem 1.25rem;
        }
        .pp-card h2 {
        font-weight: 600; font-size: 18px; margin-bottom: 0.5rem;
        }
        .pp-card p { color: rgba(#111827,0.9);}
        .pp-list { margin: .5rem 0 0 0; display: grid; gap: .35rem; color: rgba(17,24,39,.75); padding-left: 1.2rem;
        li { list-style: inside disc; }
        }
        .pp-list-terms{
        display: flex; flex-direction: column;
        gap: 8px;
        margin: .5rem 0 0 0; padding-left: 1.2rem; color: rgba(17,24,39,.75);
        list-style: none;
        }

        /* Table */
        .pp-table {
        width: 100%; margin-top: .75rem; border-collapse: collapse; font-size: .95rem;
        th, td { border: 1px solid rgba(17,24,39,.14); padding: .6rem .7rem; }
        thead th { background: rgba(326262,.08); color: #111827; text-align: left; }
        }

        /* Details */
        .pp-details {
        margin-top: .6rem; border: 1px dashed rgba(17,24,39,.14); border-radius: 10px; padding: .6rem .8rem;
        summary { cursor: pointer; font-weight: 600; color: 326262; }
        }

        /* Back to top */
        .pp-backtop {
        display: inline-block; margin-top: .25rem;
        padding: .6rem 1rem; border-radius: .6rem;
        background: 326262; color: #fff; text-decoration: none; font-weight: 600;
        box-shadow: inset 0 -2px 0 rgba(255,255,255,.12);
        transition: opacity .2s ease;
        &:hover { opacity: .95; }
        color: #fff !important;

        }
        /* Links */
        .pp-root a { color: 326262; }

        /* Small screens */
        @media (max-width: 1024px) {
        .pp-toc { position: static; }
        }
        .pp-description{
            color: #0F204B;
            font-size: 16px;
            font-style: normal;
            font-weight: 600;
            line-height: 21px; /* 131.25% */
        }
    </style>
</Layout>
