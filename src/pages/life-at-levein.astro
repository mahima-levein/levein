  <script type="module">
    document.addEventListener("DOMContentLoaded", () => {
      const cards = document.querySelectorAll(".life-video-card");
      cards.forEach((card) => {
            const video = card.querySelector(".life-video");
            if (!video) return;

            video.muted = false;
            video.volume = 1;

            const playVideo = async () => {
              try {
                await video.play();
              } catch {
                console.warn("Video playback failed, likely due to autoplay restrictions. Muting video and trying again.");
              }
            };

            const resetVideo = () => {
              video.pause();
              video.currentTime = 0;
            };

            card.addEventListener("mouseenter", playVideo);
            card.addEventListener("mouseleave", resetVideo);
          });
        });
  </script>

