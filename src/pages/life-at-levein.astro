          class="absolute inset-0 bg-[#326262]/80 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-6 text-center"
        >
          <h3
            class="text-white text-xl font-medium mb-1 font-primary translate-y-4 group-hover:translate-y-0 transition-transform duration-500 ease-out"
          >
            Levein Aurudu 2024
          </h3>
          <p
            class="text-[#93D7B0] text-sm translate-y-4 group-hover:translate-y-0 transition-transform duration-500 delay-75 ease-out"
          >
            April 25, 2024
          </p>
        </div>
      </div>

      <div
        class="group relative overflow-hidden rounded-3xl h-[250px] sm:h-[300px] lg:col-span-3"
