            </svg>
          </a>

          <a
            href="https://www.facebook.com/lifeatlevein/"
            aria-label="Facebook"
            class="footer-social-link"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
            >
              <path
                d="M9.9998 0C4.47711 0 0 4.49365 0 10.0367C0 14.7436 3.22874 18.6932 7.58425 19.778V13.104H5.52229V10.0367H7.58425V8.7151C7.58425 5.29899 9.12462 3.7156 12.4662 3.7156C13.0997 3.7156 14.1929 3.84046 14.6401 3.96491V6.74509C14.4041 6.7202 13.9941 6.70775 13.4849 6.70775C11.8454 6.70775 11.2118 7.33123 11.2118 8.95196V10.0367H14.4781L13.9169 13.104H11.2118V20C16.1633 19.3998 20 15.1683 20 10.0367C19.9996 4.49365 15.5225 0 9.9998 0Z"
                fill="#1A1617"></path>
            </svg>
          </a>

          <a
            href="https://x.com/leveingroup"
            aria-label="X"
            class="hidden"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
            >
              <path
                d="M15.7512 0H18.818L12.1179 8.47179L20 20H13.8284L8.99458 13.0082L3.46359 20H0.394938L7.5613 10.9385L0 0H6.32828L10.6976 6.39077L15.7512 0ZM14.6748 17.9692H16.3742L5.4049 1.9241H3.58133L14.6748 17.9692Z"
                fill="#1A1617"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Company, Resources, Legal grouped as single column unit -->
      <div
        class="lg:col-span-3 grid grid-cols-2 md:flex md:flex-row lg:flex-row gap-4 space-y-4 md:space-y-0 lg:gap-0"
      >
        <!-- Company -->
        <div class="flex-1">
          <h3 class="text-[20px] font-semibold leading-none text-[#061414]">
            Company
          </h3>

          <ul class="mt-6 space-y-6">
            {
              companyLinks.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-[16px] leading-none text-[#326262] text-primary no-underline transition-colors duration-300 hover:text-[#326262]/80"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <!-- Resources -->
        <div class="flex-1">
          <h3 class="text-[20px] font-semibold leading-none text-[#061414]">
            Resources
          </h3>

          <ul class="mt-6 space-y-6">
            {
              resourceLinks.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-[16px] leading-none text-[#326262] text-primary no-underline transition-colors duration-300 hover:text-[#326262]/80"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <!-- Legal -->
        <div class="flex-1">
          <h3 class="text-[20px] font-semibold leading-none text-[#061414]">
            Legal
          </h3>

          <ul class="mt-6 space-y-6">
            {
              legalLinks.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-[16px] leading-none text-primary text-[#326262] no-underline transition-colors duration-300 hover:text-[#326262]/80"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Contact -->
      <div
        class="lg:col-span-1 flex flex-col items-start lg:items-end text-left lg:text-right gap-2"
      >
        <a
          href="/contact-us"
          class="hidden lg:inline-flex h-10 items-center justify-center rounded-full bg-[#326262] px-6 text-[16px] font-bold text-[#FBFBFB] no-underline transition-all duration-300 hover:bg-[#1a1617]"
        >
          Request a call
        </a>

        <div class="mt-4 space-y-4">
          <a
            href="tel:+94112515053"
            class="block text-[16px] font-medium leading-none text-[#061414] underline underline-offset-4"
          >
            (+94) 112 515 053
          </a>

          <a
            href="mailto:hello@leveingroup.com"
            class="block text-[16px] font-medium leading-none text-[#061414] underline underline-offset-4"
          >
            hello@leveingroup.com
          </a>
          <a
            href="https://maps.app.goo.gl/7BoEWQn5KD3WEh217"
            target="_blank"
            rel="noopener noreferrer"
            class="block text-[16px] font-medium leading-none text-[#061414] underline underline-offset-4"
          >
            View Our Location
          </a>
        </div>
      </div>
    </div>

    <!-- Email row -->
    <div
      class="mt-16 grid grid-cols-[1fr_400px] items-center gap-10 max-md:mt-12 max-md:grid-cols-1"
    >
      <h2
        class="max-w-xl text-[28px] font-medium leading-[1.1] tracking-[-0.5px] text-[#1A1617] max-md:text-[24px]"
      >
        Just send us your contact email and we will contact you.
      </h2>

      <div class="flex w-full flex-col items-start">
        <form
          class="relative w-full"
          data-newsletter-form
          onsubmit="return false;"
        >
          <label for="footer-email" class="sr-only">Email address</label>

          <input
            id="footer-email"
            type="email"
            placeholder="Email address"
            class="h-10 w-full rounded-full border-0 bg-[#FBFBFB] px-4 pr-12 py-3 text-[16px] text-[#1A1617] outline-none placeholder:text-[#646464] focus:ring-2 focus:ring-[#326262]/30 border-[#000000]/10 transition-colors duration-300 focus:border-[#326262] focus:ring-offset-0 max-md:mb-4"
          />

          <button
            type="button"
            aria-label="Submit email"
            data-newsletter-submit
            class="absolute right-2 top-1/2 flex size-5 -translate-y-4 md:-translate-y-1/2 items-center justify-center rounded-full text-[#1A1617] transition-colors duration-300 hover:bg-[#e3f0e0]"
          >
            <span class="leading-none"
              ><svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 20 20"
                fill="none"
              >
                <path
                  d="M10.0003 18.3346C14.6027 18.3346 18.3337 14.6037 18.3337 10.0013C18.3337 5.39893 14.6027 1.66797 10.0003 1.66797C5.39795 1.66797 1.66699 5.39893 1.66699 10.0013C1.66699 14.6037 5.39795 18.3346 10.0003 18.3346Z"
                  stroke="#1A1617"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
                <path
                  d="M7.08301 10H12.083"
                  stroke="#1A1617"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
                <path
                  d="M10.417 12.5L12.917 10L10.417 7.5"
                  stroke="#1A1617"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg></span
            >
          </button>
        </form>

        <p
          data-newsletter-message
          class="mt-3 hidden text-sm font-medium text-[#326262]"
          role="status"
          aria-live="polite"
        >
          Thank you for subscribing to our newsletter.
        </p>
      </div>
    </div>
  </div>

  <!-- Container 02: Copyright + large wordmark -->
  <div
    class="mx-auto mt-7 lg:mt-14 max-w-7xl border-t border-[#7FCFA8] pb-0 pt-6 max-md:w-[calc(100%-32px)]"
  >
    <p class="text-center text-[16px] font-medium text-[#1A1617]">
      © {new Date().getFullYear()} LEVEIN. All rights reserved.
    </p>
  </div>

  <div
    class="relative mt-6 lg:mt-12 h-[clamp(72px,14vw,355px)] w-full overflow-hidden"
  >
    <Image
      src={FooterImg}
      alt="Levein wordmark"
      class="absolute bottom-0 left-1/2 w-full h-auto -translate-x-1/2 object-cover sm:w-[88vw] lg:w-screen"
    />
  </div>
</footer>

<script is:inline>
  const newsletterForm = document.querySelector("[data-newsletter-form]");
  const newsletterMessage = document.querySelector("[data-newsletter-message]");
  const newsletterInput = document.querySelector("#footer-email");
  const newsletterSubmit = document.querySelector("[data-newsletter-submit]");

  let newsletterTimeoutId;

  const showNewsletterMessage = (event) => {
    event?.preventDefault?.();

    if (!newsletterMessage) {
      return;
    }

    newsletterMessage.textContent =
      "Thank you for subscribing to our newsletter.";
    newsletterMessage.classList.remove("hidden");

    if (newsletterTimeoutId) {
      window.clearTimeout(newsletterTimeoutId);
    }

    newsletterTimeoutId = window.setTimeout(() => {
      newsletterMessage.classList.add("hidden");
    }, 3000);

    if (newsletterInput instanceof HTMLInputElement) {
      newsletterInput.value = "";
    }
  };

  newsletterForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    showNewsletterMessage(event);
  });

  newsletterSubmit?.addEventListener("click", showNewsletterMessage);
</script>
