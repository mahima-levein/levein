---
import "@styles/Footer.scss";
import { Image } from "astro:assets";
import FooterImg from "@assets/footer-white.png";

const companyLinks = [
  { label: "Contact", href: "/contact-us" },
  { label: "Life at Levein", href: "/life-at-levein" },
  { label: "About us", href: "/about-us" },
  { label: "Careers", href: "/careers" },
];

const resourceLinks = [
  { label: "Blogs", href: "/blogs" },
  { label: "My Application", href: "/my-application" },
  { label: "Vacancy Alerts", href: "/vacancy-alerts" },
];

const legalLinks = [
  { label: "Terms and conditions", href: "/terms-and-conditions" },
  { label: "Privacy policy", href: "/privacy-policy" },
];
---

<footer class="relative overflow-hidden bg-[#E3F0E0] text-[#1A1617]">
  <!-- Container 01: Footer main content -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full pt-14 max-md:pt-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-10 lg:gap-8">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-2 pr-4">
        <a
          href="/"
          class="block text-[38px] font-black italic leading-none tracking-[-1.5px] text-[#1A1617] no-underline"
        >
          LEVEIN
        </a>

        <p class="mt-4 max-w-2xl text-[16px] leading-relaxed text-primary">
          We're constantly seeking talented individuals who are passionate about
          working on innovative projects. If you have a knack for creativity and
          a drive to make an impact, we’d love to collaborate with you.
        </p>

        <div
          class="mt-5 inline-flex items-center gap-4 rounded-full border border-[#326262] px-5 py-3"
        >
          <a
            href="https://lk.linkedin.com/company/levein-group"
            aria-label="LinkedIn"
            class="footer-social-link"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
            >
              <path
