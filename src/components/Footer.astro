                fill="#1A1617"></path>
            </svg>
          </a>

          <a
            href="https://www.instagram.com/lifeatlevein/?hl=en"
            aria-label="Instagram"
            class="footer-social-link"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
            >
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M10.0003 1.66797C7.73699 1.66797 7.45366 1.67741 6.56477 1.71797C5.67755 1.75852 5.07144 1.89964 4.54144 2.10575C3.98588 2.31464 3.48199 2.64241 3.06533 3.06686C2.64156 3.48304 2.31358 3.98658 2.10421 4.54241C1.89921 5.07241 1.75755 5.67908 1.71699 6.5663C1.67699 7.45464 1.66699 7.73741 1.66699 10.0013C1.66699 12.2652 1.67644 12.548 1.71699 13.4369C1.75755 14.3241 1.89866 14.9302 2.10477 15.4602C2.31366 16.0157 2.64144 16.5196 3.06588 16.9363C3.48208 17.3601 3.98561 17.688 4.54144 17.8974C5.07144 18.103 5.67755 18.2441 6.56477 18.2846C7.45366 18.3252 7.73699 18.3346 10.0003 18.3346C12.2637 18.3346 12.547 18.3252 13.4359 18.2846C14.3231 18.2441 14.9292 18.103 15.4592 17.8969C16.0148 17.688 16.5187 17.3602 16.9353 16.9357C17.3591 16.5196 17.6871 16.016 17.8964 15.4602C18.102 14.9302 18.2431 14.3241 18.2837 13.4369C18.3242 12.548 18.3337 12.2646 18.3337 10.0013C18.3337 7.73797 18.3242 7.45464 18.2837 6.56575C18.2431 5.67852 18.102 5.07241 17.8959 4.54241C17.6867 3.98634 17.3587 3.48259 16.9348 3.0663C16.5186 2.64254 16.0151 2.31456 15.4592 2.10519C14.9292 1.90019 14.3225 1.75852 13.4353 1.71797C12.547 1.67797 12.2642 1.66797 10.0003 1.66797ZM10.0003 3.16964C12.2253 3.16964 12.4892 3.17797 13.3681 3.21797C14.1803 3.25519 14.6214 3.39019 14.9153 3.50519C15.3042 3.65575 15.582 3.83686 15.8737 4.12797C16.1653 4.41964 16.3459 4.69741 16.4964 5.0863C16.6109 5.38019 16.7464 5.8213 16.7837 6.63352C16.8237 7.51241 16.832 7.7763 16.832 10.0013C16.832 12.2263 16.8237 12.4902 16.7837 13.3691C16.7464 14.1813 16.6114 14.6224 16.4964 14.9163C16.3631 15.2783 16.1503 15.6057 15.8737 15.8746C15.6048 16.1513 15.2773 16.3641 14.9153 16.4974C14.6214 16.6119 14.1803 16.7474 13.3681 16.7846C12.4892 16.8246 12.2259 16.833 10.0003 16.833C7.77477 16.833 7.51144 16.8246 6.63255 16.7846C5.82033 16.7474 5.37921 16.6124 5.08533 16.4974C4.72336 16.364 4.39588 16.1512 4.12699 15.8746C3.85042 15.6057 3.63762 15.2783 3.50421 14.9163C3.38977 14.6224 3.25421 14.1813 3.21699 13.3691C3.17699 12.4902 3.16866 12.2263 3.16866 10.0013C3.16866 7.7763 3.17699 7.51241 3.21699 6.63352C3.25421 5.8213 3.38921 5.38019 3.50421 5.0863C3.65477 4.69741 3.83588 4.41964 4.12699 4.12797C4.39585 3.85133 4.72333 3.63851 5.08533 3.50519C5.37921 3.39075 5.82033 3.25519 6.63255 3.21797C7.51144 3.17797 7.77533 3.16964 10.0003 3.16964Z"
