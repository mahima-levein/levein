---
import { Image } from "astro:assets";

import teamSliderOne from "@assets/team/slider/chanaka.png";
import teamSliderTwo from "@assets/team/slider/dilki.png";
import teamSliderThree from "@assets/team/slider/hr-1.png";
import teamSliderFour from "@assets/team/slider/kalpa.png";
import teamSliderFive from "@assets/team/slider/pasandi.png";
import teamSliderSix from "@assets/team/slider/peruka.png";
import teamSliderSeven from "@assets/team/slider/proushth.png";
import teamSliderEight from "@assets/team/slider/shalini.png";
import teamSliderNine from "@assets/team/slider/shakila.png";
import teamSliderTen from "@assets/team/slider/wenushka.png";
import teamSliderEleven from "@assets/team/slider/mahima.png";
import teamSliderTwelve from "@assets/team/slider/madhura.png";
import teamSliderThirteen from "@assets/team/slider/madhushani.png";
import teamSliderFourteen from "@assets/team/slider/harish.png";

const rowOne = [
  {
    name: "Harishman Somaskandarasa",
    role: "Senior Software Engineer",
    message:
      "Nearly five years here helped me grow in HR, develop my skills, and feel inspired by the people-first culture.",
    image: teamSliderFourteen,
  },
  {
    name: "Dilki Maniyangamage",
    role: "HR Executive",
    message:
      "Working as an HR Executive at Levein helped me support people, improve HR processes, and grow professionally.",
    image: teamSliderTwo,
  },
  {
    name: "Isuri Dharmawardane",
    role: "Personal Assistant",
    message:
      "Levein supported my growth, valued my strengths, and gave me trust and guidance throughout my three-year journey.",
    image: teamSliderThree,
  },
  {
    name: "Wenushka Mallikarachchi",
    role: "Senior UI/UX Designer",
    message:
      "Working with Levein gave me valuable exposure, new knowledge, and a strong culture that brings people together.",
    image: teamSliderTen,
  },
  {
    name: "Proushoth Koushal",
    role: "Associate QA Engineer",
    message:
      "Working in QA helped me learn from experienced coworkers, explore IT tasks, and grow across different career paths.",
    image: teamSliderSeven,
  },
  {
    name: "Pasandi Karunathilake",
    role: "Senior Executive – Talent Acquisition ",
    message:
      "Over three years at Levein helped me grow in talent acquisition, people management, and personal development.",
    image: teamSliderFive,
  }
];

const rowOneLoop = [...rowOne, ...rowOne];

const rowTwo = [
  {
    name: "Kalpa Chamod",
    role: "Senior Software Engineer",
    message:
      "Working as a Senior Software Engineer at Levein helped me solve complex challenges, grow technically, and build meaningful solutions.",
    image: teamSliderFour,
  },
  {
    name: "Madhura Darshana",
    role: "Associate Tech Lead",
    message:
      "Levein taught me to solve complex challenges through teamwork, trust, consistency, and meaningful technology solutions.",
    image: teamSliderTwelve,
  },
  {
    name: "Peruka Gunawardana",
    role: "Senior Project Manager",
    message:
      "Levein gave me global project experience, real-world challenges, and the confidence to grow professionally and personally.",
    image: teamSliderSix,
  },
  {
    name: "Mahima Induvara",
    role: "Senior Frontend Developer",
    message:
      "Levein has been one of the best chapters of my life since joining in 2024, helping me grow, explore technologies, and discover myself.",
    image: teamSliderEleven,
  },
  {
    name: "Madhushani Nanayakkara",
    role: "Talent Acquisition",
    message:
      "Levein helped me grow through supportive leadership, teamwork, ownership, and opportunities in talent acquisition and business support.",
    image: teamSliderThirteen,
  },
  {
    name: "Shakila Piumani",
    role: "Executive Assistant",
    message:
      "Levein helped me manage fast-moving projects across time zones, improve confidence, and raise the quality of my work",
    image: teamSliderNine,
  },
];

const rowTwoLoop = [...rowTwo, ...rowTwo];

---

  <section
    class="bg-[#326262] py-16 text-[#FBFBFB] md:py-20 employee-stories-fade"
  >
    <div class="w-full">
      <!-- Top -->
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full">
        <div data-reveal-group
        data-reveal-start="top 95%" class="mb-10 grid gap-6 md:mb-12 md:grid-cols-2 md:items-start">
          <div>
            <h2
            data-reveal-heading
              class="font-primary font-normal text-4xl leading-tight tracking-tight md:text-5xl"
            >
              Employee Stories
            </h2>
          </div>

          <div class="md:pl-10">
            <p data-reveal-body class="max-w-xl text-[16px] leading-relaxed text-[#FBFBFB]/90">
              Over 150 Sri Lankan professionals have built careers through
              Levein. Here is what some of them found on the other side of the
              application.
            </p>
          </div>
        </div>
      </div>

      <!-- Cards / story slider area -->
      <div class="lg:space-y-10">
        <!-- Row 1 (marquee left) -->
        <div class="story-marquee story-marquee-left">
          <div class="story-marquee-track">
            {
              rowOneLoop.map((item, index) => (
                <article
                  class="story-card flex shrink-0 items-center gap-3 overflow-hidden rounded-3xl bg-[#F3F1EF] text-[#1A1617]"
                  aria-hidden={index >= rowOne.length}
                >
                  <div class="flex shrink-0 items-end self-end">
                    <Image
                      src={item.image}
                      alt={item.name}
                      class="h-[160px] w-[150px] object-cover md:h-55 md:w-50"
                    />
                  </div>

                  <div class="flex-1">
                    <p class="mb-1 lg:mb-4 pr-7 text-sm lg:text-[16px] leading-relaxed text-[#1A1617]/85">
                        {item.message}
                    </p>

                    <h3 class="text-base font-semibold text-[#326262] md:text-[18px]">
                      {item.name}
                    </h3>

                    <p class="mt-1 text-xs text-[#3A3B33]/50 md:text-sm">
                      {item.role}
                    </p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>

        <!-- Row 2 (marquee right) -->
        <div class="hidden lg:block story-marquee story-marquee-right md:pl-12">
          <div class="story-marquee-track">
            {
              rowTwoLoop.map((item, index) => (
                <article
                  class="story-card flex shrink-0 items-center gap-5 overflow-hidden rounded-3xl bg-[#F3F1EF] text-[#1A1617]"
                  aria-hidden={index >= rowTwo.length}
                >
                  <div class="flex shrink-0 items-end self-end">
                    <Image
                      src={item.image}
                      alt={item.name}
                      class="h-[160px] w-[150px] object-cover md:h-55 md:w-50"
                    />
                  </div>

                  <div class="flex-1">
                    <p class="mb-1 lg:mb-4 pr-7 text-sm lg:text-[16px] leading-relaxed text-[#1A1617]/85">
                      {item.message}
                    </p>

                    <h3 class="text-base font-semibold text-[#326262] md:text-[18px]">
                      {item.name}
                    </h3>

                    <p class="mt-1 text-xs text-[#3A3B33]/50 md:text-sm">
                      {item.role}
                    </p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </div>
</section>